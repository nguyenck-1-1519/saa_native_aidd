# =====================================================================
# Flutter app .env  (copy to .env — gitignored)
#
# IMPORTANT: `.env` is bundled into the app binary (it is a Flutter asset).
# Put ONLY client-side, public-by-design values here:
#   - Supabase URL + PUBLISHABLE/anon key (safe to ship in clients)
#   - Google OAuth CLIENT IDs (web + iOS) — embedded in apps by design
#
# DO NOT put server-side secrets here (they would ship extractably):
#   - SUPABASE service/secret key  → set in shell env for Supabase only
#   - GOOGLE_CLIENT_SECRET         → consumed by Supabase (config.toml via
#                                     env(GOOGLE_CLIENT_SECRET)), NOT the app
# =====================================================================

# Supabase local (run `npx supabase start` and copy the values it prints)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your_supabase_local_anon_or_publishable_key

# Google OAuth client IDs (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_web_client_id
GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id
