{
  "dart.flutterSdkPath": ".fvm/flutter_sdk",
  "dart.lineLength": 80,
  "search.exclude": {
    "**/.fvm/**": true,
    "**/.dart_tool/**": true,
    "**/build/**": true
  },
  "files.watcherExclude": {
    "**/.fvm/**": true
  },
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.rulers": [80],
    "editor.defaultFormatter": "Dart-Code.dart-code"
  }
}
